---
import Icon from './icons/Icon.astro';

const socialLinks = [
    { 
        name: 'Email',
        icon: 'email',
        href: 'mailto:your.email@example.com'
    },
    {
        name: 'GitHub',
        icon: 'github',
        href: 'https://github.com/yourusername'
    },
    {
        name: 'LinkedIn',
        icon: 'linkedin',
        href: 'https://linkedin.com/in/yourusername'
    },
    {
        name: 'Mastodon',
        icon: 'mastodon',
        href: 'https://mastodon.social/@yourusername'
    },
    {
        name: 'Bluesky',
        icon: 'bluesky',
        href: 'https://bsky.app/profile/yourusername'
    }
];
---

<section id="contact" class="py-16 bg-gray-900">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl font-display font-bold text-white mb-8 text-center">Get in Touch</h2>
        
        <div class="max-w-2xl mx-auto text-center">
            <p class="text-gray-300 mb-8">
                I'm always interested in hearing about new opportunities and collaborations.
                Feel free to reach out through any of these platforms!
            </p>
            
            <div class="flex justify-center space-x-8">
                {socialLinks.map(({ name, icon, href }) => (
                    <a
                        href={href}
                        target="_blank"
                        rel="noopener noreferrer me"
                        class="text-purple-600 hover:text-purple-500 transition-colors group"
                        aria-label={name}
                    >
                        <div class="flex flex-col items-center space-y-2">
                            <Icon name={icon} class="w-8 h-8 text-purple-600 group-hover:text-purple-500 transition-colors" />
                            <span class="text-sm text-gray-400 group-hover:text-purple-500 transition-colors">
                                {name}
                            </span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>
</section>
