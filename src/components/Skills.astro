---
const skills = [
    { category: 'Frontend Development', items: ['HTML5 & CSS3', 'JavaScript (ES6+)', 'React.js', 'Tailwind CSS'] },
    { category: 'Backend Development', items: ['Node.js', 'Python', 'SQL & NoSQL', 'RESTful APIs'] },
    { category: 'Tools & Methods', items: ['Git & GitHub', 'Docker', 'CI/CD', 'Agile/Scrum'] }
];
---

<section id="skills" class="py-20 bg-gray-900">
    <div class="container mx-auto px-4">
        <h2 class="font-display text-4xl font-bold text-center mb-12 text-white">Skills & Expertise</h2>
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {skills.map((skillSet, index) => (
                <div class="p-6 bg-gray-800/50 rounded-lg shadow-lg border border-purple-600/20">
                    <h3 class="font-display text-xl font-semibold mb-4 text-purple-500">{skillSet.category}</h3>
                    <ul class="font-sans space-y-2 text-gray-300">
                        {skillSet.items.map(skill => (
                            <li>{skill}</li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
    </div>
</section>
