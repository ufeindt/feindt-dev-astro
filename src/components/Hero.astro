---
const { title } = Astro.props;
---

<section class="min-h-screen bg-gray-900 flex items-center">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-white mb-6">Hi, I'm [Your Name]</h1>
        <p class="font-display text-xl md:text-2xl text-gray-300 mb-8">Full Stack Developer & Problem Solver</p>
        <p class="font-sans text-lg md:text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
            I build modern web applications and bring creative ideas to life through code.
        </p>
        <div class="flex justify-center space-x-4">
            <a href="#contact" class="bg-purple-600 hover:bg-purple-500 text-white font-display font-semibold px-8 py-3 rounded-lg transition-colors">
                Get in Touch
            </a>
            <a href="#projects" class="border border-purple-600 text-purple-400 hover:bg-purple-600 hover:text-white font-display font-semibold px-8 py-3 rounded-lg transition-colors">
                View Projects
            </a>
        </div>
    </div>
</section>
